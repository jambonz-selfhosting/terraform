# Terraform state files
*.tfstate
*.tfstate.*

# Terraform lock file (usually committed, but can be ignored)
# .terraform.lock.hcl

# Terraform cache
.terraform/

# Sensitive variable files
terraform.tfvars
*.auto.tfvars

# Crash log files
crash.log
crash.*.log

# Terraform log files
terraform-*.log

# Kubeconfig files (generated, contain secrets)
kubeconfig

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Testing framework artifacts
testing/config.yaml
testing/*.log
testing/.test-state-*.yaml
testing/__pycache__/
testing/lib/__pycache__/

.vscode

CLAUDE.md

# Exoscale internal scripts (not for end users)
exoscale/upload-to-sos.sh
exoscale/test-ssh-key/

# Planning docs (not for end users)
ovhcloud-terraform-plan.md
